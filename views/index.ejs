<body>
  <script type="text/javascript">
    function isWebGLSupported() {
      try {
        const canvas = document.createElement('canvas');
        return !!(window.WebGLRenderingContext && (
          canvas.getContext('webgl') || canvas.getContext('experimental-webgl'))
        );
      } catch (e) {
        return false;
      }
    }
    let type = isWebGLSupported() ? "WebGL" : "canvas";
    console.log("Pixi.js rendering type:", type);
  </script>

  <!-- audioの自動再生の許可をとるための無音ファイル -->
  <!-- https://webty.jp/staffblog/production/post-907/ -->
  <audio allow="autoplay" preload id="muonAudio" style="display:none">
    <source src='sound/etc/muon.mp3'>
  </audio>

  <div id="mainFrame">
    <div role="main" id="main" class="flexContainerColumn">
      <div id="titleBar" class="flexContainer">
        <!-- <p style="font-size:43px; color:yellow; font-weight: bold;">工事中 </p> -->
        <!-- <p style="font-size:23px; color:red; font-weight: bold;">入れん人はクッキー消して</p> -->
        <!--日付-->
        <div id="day"></div>
        <div id="title">
          <%= title %>
        </div>
      </div>


      <!--元プロ街の画面比率は11:8-->


      <!-- 立て看板モーダル -->
      <div id="signModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:#1a1a2e; border:2px solid #4a90d9; border-radius:8px; padding:20px; min-width:300px; color:#fff; font-family:monospace;">
          <p style="margin:0 0 4px; font-size:12px; color:#aac;">看板の文字</p>
          <input type="text" id="signBoardText" maxlength="20" placeholder="看板の文字（省略可）" style="width:100%; box-sizing:border-box; background:#0d0d1a; border:1px solid #4a90d9; color:#fff; padding:6px; font-size:14px; border-radius:4px;">
          <p style="margin:10px 0 4px; font-size:12px; color:#aac;">メッセージ</p>
          <input type="text" id="signClickText" maxlength="100" placeholder="クリックメッセージ（省略可）" style="width:100%; box-sizing:border-box; background:#0d0d1a; border:1px solid #4a90d9; color:#fff; padding:6px; font-size:14px; border-radius:4px;">
          <p style="margin:10px 0 4px; font-size:12px; color:#aac;">表示時間</p>
          <select id="signDuration" style="background:#0d0d1a; border:1px solid #4a90d9; color:#fff; padding:6px; border-radius:4px; width:100%;">
            <option value="300000">5分</option>
            <option value="900000">15分</option>
            <option value="1800000">30分</option>
            <option value="3600000">1時間</option>
            <option value="10800000">3時間</option>
            <option value="86400000">1日</option>
            <option value="259200000">3日</option>
            <option value="604800000">1週間</option>
            <option value="0">部屋移動まで</option>
          </select>
          <p style="margin:10px 0 4px; font-size:12px; color:#aac;">削除パスワード（省略可）</p>
          <input type="password" id="signPassword" maxlength="50" placeholder="パスワードなしは誰でも削除可" style="width:100%; box-sizing:border-box; background:#0d0d1a; border:1px solid #4a90d9; color:#fff; padding:6px; font-size:14px; border-radius:4px;">
          <div style="display:flex; gap:8px; margin-top:16px; justify-content:flex-end;">
            <button id="signCancel" style="background:#333; border:1px solid #666; color:#fff; padding:6px 16px; border-radius:4px; cursor:pointer;">キャンセル</button>
            <button id="signConfirm" style="background:#1a4a7a; border:1px solid #4a90d9; color:#fff; padding:6px 16px; border-radius:4px; cursor:pointer;">立てる</button>
          </div>
        </div>
      </div>

      <!-- 看板右クリックメニュー -->
      <div id="signContextMenu" oncontextmenu="return false" style="display:none; position:fixed; z-index:9998; background:#1a1a2e; border:1px solid #4a90d9; border-radius:4px; padding:4px 0; font-family:monospace;">
        <ul style="list-style:none; margin:0; padding:0;">
          <li id="signDeleteMenu" style="padding:8px 20px; cursor:pointer; color:#fff; white-space:nowrap;">看板を消す</li>
        </ul>
      </div>

      <!-- 看板削除確認モーダル -->
      <div id="signDeleteConfirmModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:#1a1a2e; border:2px solid #d94a4a; border-radius:8px; padding:20px; min-width:260px; color:#fff; font-family:monospace;">
          <p style="margin:0 0 16px;">看板を消しますか？</p>
          <div style="display:flex; gap:8px; justify-content:flex-end;">
            <button id="signDeleteConfirmNo" style="background:#333; border:1px solid #666; color:#fff; padding:6px 16px; border-radius:4px; cursor:pointer;">キャンセル</button>
            <button id="signDeleteConfirmYes" style="background:#7a1a1a; border:1px solid #d94a4a; color:#fff; padding:6px 16px; border-radius:4px; cursor:pointer;">消す</button>
          </div>
        </div>
      </div>

      <!-- 看板削除パスワードモーダル -->
      <div id="signDeleteModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:#1a1a2e; border:2px solid #d94a4a; border-radius:8px; padding:20px; min-width:260px; color:#fff; font-family:monospace;">
          <p style="margin:0 0 8px;">削除パスワードを入力してください</p>
          <input type="password" id="signDeletePassword" maxlength="50" placeholder="パスワード" style="width:100%; box-sizing:border-box; background:#0d0d1a; border:1px solid #d94a4a; color:#fff; padding:6px; font-size:14px; border-radius:4px;">
          <p id="signDeleteError" style="color:#f66; font-size:12px; margin:4px 0 0; display:none;">パスワードが違います</p>
          <div style="display:flex; gap:8px; margin-top:16px; justify-content:flex-end;">
            <button id="signDeleteCancel" style="background:#333; border:1px solid #666; color:#fff; padding:6px 16px; border-radius:4px; cursor:pointer;">キャンセル</button>
            <button id="signDeleteConfirm" style="background:#7a1a1a; border:1px solid #d94a4a; color:#fff; padding:6px 16px; border-radius:4px; cursor:pointer;">削除</button>
          </div>
        </div>
      </div>
      <div id="Pmachi" class="flexContainerColumn">
        <div id="Pmain" class="flexContainer">
          <div id="PmainLeft" class="flexContainerColumn">
            <div id="PmainTop" class="flexContainer">
              <div class="flexContainerColumn">
                <div id="graphic" oncontextmenu="return false">
                  <!-- <button id="loginButton" onclick="login()">LOGIN</button> -->
                   <!-- まだ残しとく前どんなんだっけって言われるかもなので、cssは消してない -->
                </div>

                <div id="form">
                  <form name="nameForm" id="nameForm" class="flexCenter">
                    <input type="text" name="userName" id="userName" maxlength='27' placeholder="名前を入れてね　※必須じゃなぃよ">
                  </form>
                  <form name="msgForm" id="msgForm" class="flexCenter">
                    <textarea name="msg" id="msg" maxlength='10000' placeholder="メッセージはこちらへ"
                      autocomplete="off" rows="1"></textarea>
                    <button type="submit" id="sendBtn" class="smartphone">⏎</button>
                  </form>
                </div>

                <!-- スイッチ類 -->
                <div id="switchBar">
                  <!-- <span class="PC">shift+Enterで改行、alt+Enterでログ残し</span> -->
                  <div class="flexContainerColumn">
                    <div class="flexspaceBetween">
                      <span class="PC">shift+Enterで改行、alt+Enterでログ残し</span>
                      <button id="train" type="button" onclick="trainClick();">&nbsp;電車&nbsp;&nbsp;&nbsp;</button>
                    </div>
                    <div class="flexspaceBetween">
                      <div class="flexContainer">
                        <button class="defaultRed" id="startVideo" type="button" onclick="startVideo();">動画配信</button>
                        <button class="defaultRed" id="startAudio" type="button" onclick="startAudio();">音声配信</button>
                      </div>
                      <div class="flexContainer">
                        <button id="checkAllListen" type="button" onclick="checkAllListenFunk();">自動受信</button>
                      </div>
                      <div class="flexContainer">
                        <button type="button" id="mainLogButton" class="smartphone defaultRed">下ログ表示</button>
                        <button type="button" id="useOverlayChatButton" class="smartphone right">画面チャット表示</button>
                      </div>
                      <div class="flexContainer">
                        <button type="button" class="right" id="wa_i">wa-i!</button>
                        <button type="button" class="right" id="clear">clear</button>
                        <button type="button" id="undo">↶↩↫↺</button>
                        <button type="button" id="redo">↷↪↬↻</button>

                      </div>
                      <button type="button" id="logNoiseButton">SE📢✖</button>
                      <button type="button" id="settingButton" onclick="settingClick();">⚙🔩🔧</button>
                      <button type="button" id="usersDisplay" onclick="usersDisplayClick();"> users:<span
                          id="usersNumber">0</span></button>
                    </div>
                  </div>
                </div>
                <!-- スイッチ類↑↑↑↑↑↑↑↑ -->
              </div>
              <div id="mainLogFrame">
                <div id="mainLog">
                  <ul id="logs" class="flexContainerColumn"></ul>
                </div>
                <div id="roomEditPanel" style="display:none;overflow-y:auto;background:#0d0d1a;color:#fff;font-size:12px;font-family:monospace;box-sizing:border-box;max-width:1000px;">
                  <!-- GATE作成セクション（内部で使用、常に非表示） -->
                  <div id="gateCreateSection" style="display:none;"></div>
                  <!-- 部屋編集セクション -->
                  <div id="roomEditSection" style="display:none;padding:8px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;border-bottom:1px solid #4a90d9;padding-bottom:6px;">
                      <span style="color:#4a90d9;font-weight:bold;font-size:13px;">部屋を編集：<span id="roomEditNameDisplay" style="color:#fff;"></span></span>
                      <button id="roomEditCloseBtn" style="background:none;border:none;color:#aaa;cursor:pointer;font-size:16px;line-height:1;">✕</button>
                    </div>
                    <div style="margin-bottom:6px;font-size:11px;color:#888;">部屋ID: <span id="roomEditRoomIdDisplay" style="color:#88aaff;font-family:monospace;word-break:break-all;"></span></div>
                    <div style="display:flex;gap:4px;margin-bottom:6px;">
                      <input type="password" id="roomEditPw" placeholder="パスワード未入力の場合、誰でも部屋を編集できます" style="flex:1;background:#111;border:1px solid #555;color:#fff;padding:4px;font-size:11px;min-width:0;" class="placeholder-gray">
                      <button id="roomEditPwToggle" style="font-size:11px;padding:2px 6px;white-space:nowrap;">表示</button>
                      <button id="roomEditAuthBtn" style="font-size:11px;padding:3px 8px;background:#1a3a6a;border:1px solid #4a90d9;color:#fff;cursor:pointer;white-space:nowrap;">読込</button>
                    </div>
                    <div id="roomEditErr" style="color:#f88;font-size:11px;min-height:1em;margin-bottom:4px;"></div>
                    <div id="roomEditMain" style="display:none;">
                      <!-- 部屋名編集 -->
                      <div style="display:flex;gap:4px;align-items:center;margin-bottom:8px;">
                        <span style="font-size:11px;color:#aaa;white-space:nowrap;">部屋名:</span>
                        <input id="roomNameEditInput" type="text" maxlength="30" style="flex:1;background:#111;border:1px solid #4a90d9;color:#fff;padding:3px;font-size:11px;min-width:0;">
                        <button id="roomNameSaveBtn" style="font-size:11px;padding:2px 8px;background:#1a3a6a;border:1px solid #4a90d9;color:#fff;cursor:pointer;">保存</button>
                      </div>
                      <div style="display:flex;gap:2px;border-bottom:1px solid #4a90d9;margin-bottom:0;">
                        <button id="roomEditTabWarp" style="font-size:11px;padding:4px 10px;background:#1a3a6a;border:1px solid #4a90d9;border-bottom:none;color:#fff;cursor:pointer;">ワープ</button>
                        <button id="roomEditTabImg" style="font-size:11px;padding:4px 10px;background:#0d0d1a;border:1px solid #4a90d9;border-bottom:none;color:#888;cursor:pointer;">画像</button>
                        <button id="roomEditTabCode" style="font-size:11px;padding:4px 10px;background:#0d0d1a;border:1px solid #4a90d9;border-bottom:none;color:#888;cursor:pointer;">コード</button>
                        <button id="roomEditTabScale" style="font-size:11px;padding:4px 10px;background:#0d0d1a;border:1px solid #4a90d9;border-bottom:none;color:#888;cursor:pointer;">スケール</button>
                      </div>
                      <!-- ワープタブ -->
                      <div id="roomEditContentWarp" style="padding-top:6px;">
                        <div style="display:flex;gap:4px;flex-wrap:wrap;align-items:center;margin-bottom:4px;">
                          <span style="font-size:11px;color:#aaa;">形状:</span>
                          <button type="button" id="warpShapeRect" style="font-size:11px;background:#1a3a6a;border:1px solid #4a90d9;color:#fff;padding:2px 6px;">矩形</button>
                          <button type="button" id="warpShapeCircle" style="font-size:11px;background:#0d0d1a;border:1px solid #4a90d9;color:#888;padding:2px 6px;">円</button>
                          <button type="button" id="warpShapeEllipse" style="font-size:11px;background:#0d0d1a;border:1px solid #4a90d9;color:#888;padding:2px 6px;">楕円</button>
                          <button type="button" id="warpPlaceBtn" style="font-size:11px;margin-left:4px;">配置</button>
                          <button type="button" id="warpPlaceStopBtn" style="font-size:11px;display:none;">終了</button>
                        </div>
                        <div id="warpDelErr" style="color:#f88;font-size:11px;min-height:1em;margin-bottom:2px;"></div>
                        <div id="warpList" style="max-height:400px;overflow-y:auto;margin-top:2px;"></div>
                      </div>
                      <!-- 画像タブ -->
                      <div id="roomEditContentImg" style="display:none;padding-top:6px;">
                        <div style="display:flex;gap:4px;align-items:center;margin-bottom:4px;flex-wrap:wrap;">
                          <select id="imgType" style="background:#0d0d1a;border:1px solid #4a90d9;color:#fff;padding:2px;font-size:11px;">
                            <option value="background">背景</option>
                            <option value="platform">足場</option>
                            <option value="object">オブジェクト</option>
                          </select>
                          <input type="file" id="imgFileInput" accept="image/png,image/jpeg" style="display:none">
                          <button type="button" id="imgUploadBtn" style="font-size:11px;">ファイルから</button>
                          <button type="button" id="imgDoodleBtn" style="font-size:11px;">落書き</button>
                        </div>
                        <!-- 落書きキャンバス（toggle） -->
                        <div id="doodleArea" style="display:none;border:1px solid #4a90d9;margin-bottom:6px;">
                          <div style="display:flex;gap:4px;align-items:center;padding:4px;flex-wrap:wrap;">
                            <span style="font-size:11px;color:#aaa;">名前:</span>
                            <input id="doodleNameInput" type="text" value="ラクガキ1" maxlength="30" style="width:80px;background:#111;border:1px solid #4a90d9;color:#fff;padding:2px;font-size:11px;">
                            <span style="font-size:11px;color:#aaa;">色:</span>
                            <div id="doodlePalette" style="display:flex;gap:2px;flex-wrap:wrap;"></div>
                            <input id="doodleCustomColor" type="color" value="#ffffff" style="width:24px;height:24px;padding:0;border:none;background:none;cursor:pointer;" title="カスタム色">
                            <span style="font-size:11px;color:#aaa;">太さ:</span>
                            <input id="doodleLineWidth" type="range" min="1" max="20" value="3" style="width:60px;">
                            <button id="doodleClearBtn" style="font-size:11px;">消去</button>
                            <button id="doodleSaveBtn" style="font-size:11px;background:#1a3a6a;border:1px solid #4a90d9;color:#fff;cursor:pointer;">画像として追加</button>
                          </div>
                          <div id="doodleCanvasInstruction" style="display:none;padding:20px;text-align:center;color:#aaa;font-size:12px;background:#111;border-top:1px solid #333;">画面に直接描いてください。描き終えたら「画像として追加」を押してください。</div>
                          <canvas id="doodleCanvas" width="330" height="230" style="display:block;background:#fff;cursor:crosshair;touch-action:none;max-width:100%;"></canvas>
                        </div>
                        <div id="imgList" style="max-height:400px;overflow-y:auto;margin-top:4px;"></div>
                      </div>
                      <!-- コードタブ -->
                      <div id="roomEditContentCode" style="display:none;padding-top:6px;">
                        <textarea id="codeEditor" rows="8" placeholder="// parent.PIXI / parent.app / parent.customStage が使えます" style="width:100%;background:#0d0d1a;border:1px solid #4a90d9;color:#fff;padding:4px;font-size:11px;font-family:monospace;resize:vertical;box-sizing:border-box;"></textarea>
                        <div style="display:flex;gap:4px;margin-top:4px;flex-wrap:wrap;">
                          <button type="button" id="codeTestBtn" style="font-size:11px;">テスト実行</button>
                          <button type="button" id="codeSaveBtn" style="font-size:11px;">保存</button>
                          <button type="button" id="codeLoadSampleBtn" style="font-size:11px;">テストコードを読み込む</button>
                        </div>
                        <div id="codeMsg" style="font-size:11px;margin-top:4px;color:#aaa;"></div>
                        <!-- コードルール -->
                        <details style="margin-top:8px;">
                          <summary style="font-size:11px;color:#88aaff;cursor:pointer;">コードの書き方（クリックで展開）</summary>
                          <div id="codeRulesBox" style="background:#111;border:1px solid #4a90d9;padding:8px;margin-top:4px;font-size:10px;line-height:1.6;white-space:pre-wrap;color:#cce;"></div>
                          <button type="button" id="codeRulesCopyBtn" style="font-size:11px;margin-top:4px;">ルールをコピー（AIに貼り付け用）</button>
                        </details>
                      </div>
                      <!-- スケールタブ -->
                      <div id="roomEditContentScale" style="display:none;padding-top:6px;">
                        <div style="display:flex;gap:6px;align-items:center;margin-bottom:8px;flex-wrap:wrap;">
                          <span style="font-size:11px;color:#aaa;white-space:nowrap;">全体スケール:</span>
                          <input type="range" id="roomScaleSlider" min="0.1" max="3" step="0.05" value="1" style="flex:1;min-width:80px;">
                          <input type="number" id="roomScaleInput" min="0.1" max="10" step="0.05" value="1" style="width:52px;background:#0d0d1a;border:1px solid #4a90d9;color:#fff;padding:2px;font-size:11px;">
                          <button type="button" id="roomScaleSaveBtn" style="font-size:11px;">保存</button>
                        </div>
                        <div style="display:flex;gap:4px;align-items:center;margin-bottom:4px;">
                          <button type="button" id="scaleZonePlaceBtn" style="font-size:11px;">エリア追加</button>
                          <button type="button" id="scaleZonePlaceStopBtn" style="font-size:11px;display:none;">終了</button>
                        </div>
                        <div id="scaleZoneErr" style="color:#f88;font-size:11px;min-height:1em;margin-bottom:2px;"></div>
                        <div id="scaleZoneList" style="max-height:300px;overflow-y:auto;margin-top:2px;"></div>
                      </div>
                      <div style="margin-top:12px;border-top:1px solid #333;padding-top:8px;">
                        <button id="roomDeleteBtn" type="button" style="font-size:11px;background:#3a0a0a;border:1px solid #a03030;color:#ffaaaa;padding:3px 10px;cursor:pointer;">この部屋を削除</button>
                        <div id="roomDeleteConfirm" style="display:none;margin-top:6px;background:#1a0000;border:1px solid #c04040;padding:8px;border-radius:3px;">
                          <div style="font-size:12px;color:#ff8888;margin-bottom:6px;">本当に削除しますか？<br><span style="font-size:10px;color:#aaa;">元に戻せません。部屋・画像・ワープがすべて消えます。</span></div>
                          <div id="roomDeletePassWrap" style="display:none;margin-bottom:6px;">
                            <input id="roomDeletePassInput" type="password" placeholder="編集パスワード" style="background:#0d0d1a;border:1px solid #c04040;color:#fff;padding:3px 6px;font-size:11px;width:100%;box-sizing:border-box;">
                          </div>
                          <div id="roomDeleteErr" style="color:#f88;font-size:11px;min-height:1em;margin-bottom:4px;"></div>
                          <div style="display:flex;gap:6px;">
                            <button id="roomDeleteConfirmBtn" type="button" style="font-size:11px;background:#800;border:1px solid #c04040;color:#fff;padding:3px 12px;cursor:pointer;">削除する</button>
                            <button id="roomDeleteCancelBtn" type="button" style="font-size:11px;background:#222;border:1px solid #666;color:#aaa;padding:3px 12px;cursor:pointer;">キャンセル</button>
                          </div>
                        </div>
                      </div>
                      <div style="margin-top:8px;font-size:13px;color:#ff9900;font-weight:bold;">⚠ 部屋は一日誰も出入りがなかったら消えます。</div>
                      <!-- 右下3ボタン（sticky） -->
