#!/usr/bin/env node

/**
 * モジュールの読み込み
 */
const appModule = require('../app');               // Expressアプリ本佁E
const app = appModule;
const debug = require('debug')('pmachi6:server'); // チE��チE��用
const fs = require('fs');                          // ファイル操作用
const http = require('http');                      // HTTPサーバ�E用
const https = require('https');                    // HTTPSサーバ�E用

/**
 * ポ�Eト番号を正規化する関数
 * - 数字ならそのまま返す
 * - named pipe なら文字�Eを返す
 * - 無効なめEfalse を返す
 */
function normalizePort(val) {
  const port = parseInt(val, 10);
  if (isNaN(port)) {
    // 数字に変換できなければ named pipe とみなぁE
    return val;
  }
  if (port >= 0) {
    // 正の数字なら�Eート番号として返す
    return port;
  }
  return false; // 無効なポ�EチE
}



//サーバ�Eエラー時�E処琁E
function onError(error) {
  if (error.syscall !== 'listen') {
    throw error; // listen 系のエラーでなければ投げめE
  }

  const bind = typeof port === 'string'
    ? 'Pipe ' + port  // named pipe の場吁E
    : 'Port ' + port; // ポ�Eト番号の場吁E

  // 特定�Eエラーに対してわかりやすいメチE��ージ
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' は管琁E��E��限が忁E��でぁE);
      process.exit(1);
    case 'EADDRINUSE':
      console.error(bind + ' は既に使用中でぁE);
      process.exit(1);
    default:
      throw error;
  }
}


// サーバ�Eが起動したとき�E処琁E
function onListening() {
  const addr = server.address();
  const bind = typeof addr === 'string'
    ? 'pipe ' + addr      // named pipe の場吁E
    : 'port ' + addr.port; // ポ�Eト番号の場吁E
  debug('Listening on ' + bind); // チE��チE��用出劁E
}


// 環墁E��数めE��フォルト値からポ�Eト番号を取得して Express に設宁E
const port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * サーバ�E作�E
 * - SSL キーファイルがあれ�E HTTPS
 * - なければ HTTP
 */
let server;

try {
  // SSL 証明書ファイルのパス
  const nmachi_key = '../../../../usr/local/nginx/nmachi20201226.key';
  const nmachi_crt = '../../../../usr/local/nginx/nmachi20220126.crt';
  const nmachi_chain = '../../../../usr/local/nginx/nmachi20220126.pem';

  // SSL オプション作�E
  const options = {
    key: fs.readFileSync(nmachi_key),
    cert: fs.readFileSync(nmachi_crt),
    ca: fs.readFileSync(nmachi_chain)
  };

  // HTTPS サーバ�E作�E
  server = https.createServer(options, app);
  console.log('HTTPS サーバ�Eを作�Eしました');
} catch (err) {
  // ファイルが見つからなければ HTTP にフォールバック
  console.warn('SSL ファイルが見つかりません、ETTP サーバ�Eに刁E��替えまぁE);
  server = http.createServer(app);
}

// Socket.IO のセチE��アチE�E - クライアントとリアルタイム通信するためのライブラリ
const io = require('socket.io')(server);


// 環墁E��応じてサーバ�Eのバインド�Eを決宁E
// NODE_ENV ぁE'production' の場吁EↁE本番環墁E��みなぁElocalhost にバインチE
// Codespaces 上�E場吁EↁEprocess.env.CODESPACE が設定されてぁE��ので 0.0.0.0 にバインド（外部アクセス可能�E�E
// それ以外（通常ローカル開発など�E�EↁElocalhost にバインチE

// 部屋アトラスの生�Eを征E��てからサーバ�E起勁E
(appModule.atlasReady || Promise.resolve()).then(() => {
  server.listen(port, '0.0.0.0', () => {
    console.log(`Server running at port ${port}/`);
  });
});
server.on('error', onError);
server.on('listening', onListening);


let ip = {};

let user = {};
let socketID = {};
let tokenNum = 0;

let rooms = {};
let roomNameList = ["エントランス", "草原", "ぁE��めE�E", "昁E",];
for (let i = 0; i < roomNameList.length; i++) {
  rooms[roomNameList[i]] = {
    drawHistory: [],
    usersToken: new Set(),
    signs: [],
  };
}

const crypto = require("crypto");

function tripCreate(isTrip) {
  let tripkey = isTrip;
  // ソルト生成！E斁E��以上になるよぁE�� 'H.' を追加し、E斁E��目と3斁E��目を�Eり�Eし！E
  let salt = (tripkey + "H.").slice(1, 3);
  salt = salt.replace(/[^.-z]/g, ".");
  salt = salt.replace(/:/g, "A");
  salt = salt.replace(/;/g, "B");
  salt = salt.replace(/</g, "C");
  salt = salt.replace(/=/g, "D");
  salt = salt.replace(/>/g, "E");
  salt = salt.replace(/\?/g, "F");
  salt = salt.replace(/@/g, "G");
  salt = salt.replace(/\[/g, "a");
  salt = salt.replace(/\\/g, "b");
  salt = salt.replace(/]/g, "c");
  salt = salt.replace(/\^/g, "d");
  salt = salt.replace(/_/g, "e");
  salt = salt.replace(/`/g, "f");

  // AES用のキーとIVを生成！E6バイトずつ、saltを埋めて残りは0埋め�E�E
  const key = Buffer.alloc(32, 0); // AES-256なので32バイチE
  key.write(salt, 0, "utf-8");
  const iv = Buffer.alloc(16, 0);  // IVは16バイチE
  iv.write(salt, 0, "utf-8");

  // 暗号匁E
  const cipher = crypto.createCipheriv("aes-256-cbc", key, iv);
  let encrypted = cipher.update(tripkey, "utf-8", "base64");
  encrypted += cipher.final("base64");

  // トリチE�Eとして末尾10斁E��！Eは除去�E�E
  let trip = encrypted.substr(-10).replace(/=/g, "");
  trip = "◁E + trip;
  return trip;
}

let msgSE = {};
msgSE.login = {};
msgSE.login.in = new Array(0);
msgSE.login.logout = new Array(0);
msgSE.other = {};
msgSE.other.in = new Array(1);
msgSE.other.out = new Array(3);
msgSE.other.logout = new Array(1);
msgSE.outerSpace = {};
msgSE.outerSpace.in = new Array(1);
msgSE.outerSpace.out = new Array(1);
msgSE.outerSpace.logout = new Array(1);

function time() {
  return " -- " + new Date().getHours().toLocaleString() + ":" + new Date().getMinutes().toLocaleString() + "--";
}


// 部屋名→SEキーのマッピング。新しい部屋を追加するとき�Eここに追訁E
const ROOM_SE_KEY = {
  "エントランス": "other",
  "草原":         "other",
  "ぁE��めE�E":    "outerSpace",
  "昁E":         "outerSpace",
};

let random;
function volumeRandom(roomName, move) {
  const key = ROOM_SE_KEY[roomName] || roomName;
  random = Math.floor(Math.random() * msgSE[key][move].length);
  return random;
}

//昁Eの星�E色用ランダムカラー配�E作�E
const starColors = [];
setStarRandomColor();

function setStarRandomColor() {
  starColors.length = 0;
  for (let i = 0; i < 1000; i++) {
    // 0x000000�E�ExFFFFFFのランダムカラー
    starColors.push(Math.floor(Math.random() * 0xFFFFFF));
  }
}


// クライアントがサーバ�Eに接続したとき�E処琁E
io.on('connection', socket => {
  // ユーザーごとに一意なト�Eクンを発衁E
  const token = crypto.randomUUID();
  socketID[token] = socket.id;

  // サーバ�E再起動時にクライアントへ再読み込みを俁E��メチE��ージを送る関数
  function checkUser() {
    if (!user[token]) {
      io.to(socket.id).emit("emitSaikiMsg", {
        msg: "ブラウザを更新してください",
      });
      return false;
    }
    return true;
  }

  /**
 * ユーザーが寝てたら起こす関数、E
 * sleepTimeNumぁE0刁E��上かつselfSleepがfalseの場合、ユーザーのsleep状態をfalseに設定し、E
 * 対応するルームにsleepイベントを送信します。その後、sleepTimeNumをリセチE��します、E
 */
  function sleepTime() {
    if (user[token].sleepTimeNum >= 30 * 60 && user[token].selfSleep == false) {
      user[token].sleep = false;
      io.to(user[token].room).emit("sleep", {
        token: token,
        sleep: user[token].sleep,
      });
    }
    user[token].sleepTimeNum = 0;
  }



  // ユーザー惁E��を取得するイベンチE
  socket.on("getMyUser", () => {
    // ユーザー惁E��を�E期化して保孁E
    user[token] = {
      userName: "名もなき名無ぁE, // チE��ォルト名
      token: token,
      AX: 457, // 初期X座樁E
      AY: 80,  // 初期Y座樁E
      DIR: "S", // 初期向き
      msg: "",
      tarAspect: "gomaneco", // チE��ォルトアバター
      room: "loginRoom",   // 初期部屁E
      video: false,
      audio: false,
      timeShade: new Date().getHours(),
      avatarAlpha: 1.0,//アバターの透�E度
      sleep: false,
      sit: false,
      selfSleep: false,//ユーザー自身で設定した眠り状慁E
      sleepTimeNum: 0,
      drawHistory: [],
      allowOthersOekaki: true,
      carryOver: false,//ログ残し状態かどぁE��
      // ⭁E乗車状況�E初期匁E
      ridingObject: null,
      ridingOffsetX: 0,
      ridingOffsetY: 0,

      // 一定時間操作がなければ自動でスリープ状態にする関数
      countSleep: () => {
        let setTimeoutSleep;
        if (user[token]) {
          user[token].sleepTimeNum++;
          // 30刁E��E800秒）経過でスリーチE
          if (user[token].sleepTimeNum == 30 * 60) {
            user[token].sleep = true;
            io.to(user[token].room).emit("sleep", {
              token: token,
              sleep: user[token].sleep,
            });
          }
          setTimeoutSleep = setTimeout(user[token].countSleep, 1000); // 1秒ごとにカウンチE
        } else {
          clearTimeout(setTimeoutSleep); // ユーザーがいなければタイマ�E解除
        }
      },
    }

    tokenNum++;

    io.to(socket.id).emit("userInit", {
      token: token,
    });
    user[token].countSleep();
  });


  socket.on("joineRoom", data => {//部屋移勁E
    if (!checkUser()) return;

    // 再接続時�E�指定部屋が現存しなければ失敗を通知
    if (data.isReconnect && !roomNameList.includes(data.toRoom)) {
      io.to(socket.id).emit("reconnectFailed");
      return;
    }

    let announce;
    let fromRoom = user[token].room;
    user[token].room = data.toRoom;
    rooms[data.toRoom].usersToken.add(token);//部屋�Eユーザーリストに追加
    user[token].carryOver = false;

    if (user[token].ridingObject) {
      // 乗車情報をリセチE��
      user[token].ridingObject = null;
      user[token].ridingOffsetX = 0;
      user[token].ridingOffsetY = 0;
    }


    if (fromRoom === "loginRoom" && data.userName.length < 28) {//ログインの時かつ、名前が28未満の晁E
      //トリチE�Eを作る
      if (!ip[socket.handshake.address]) {
        ip[socket.handshake.address] = { name: [data.userName], ip: socket.handshake.address };
      } else {
        if (!ip[socket.handshake.address].name.includes(data.userName)) {
          ip[socket.handshake.address].name.push(data.userName);
        }
      }
      data.userName = data.userName.replace(/◁Eg, '□');
      if (data.userName.match(/#/)) {
        let index = data.userName.indexOf("#");
        let tripStr = data.userName.slice(index + 1);
        let tripName = data.userName.slice(0, index);
        data.userName = tripName + tripCreate(tripStr);
      }
      if (data.userName.match(/�E�E)) {
        let index = data.userName.indexOf("�E�E);
        let tripStr = data.userName.slice(index + 1);
        let tripName = data.userName.slice(0, index);
        data.userName = tripName + tripCreate(tripStr);
      }
      user[token].userName = data.userName;//名前をサバに保孁E
      user[token].avatarAspect = data.avatarAspect;//アバターを設宁E
      user[token].avatarColor = data.avatarColor;//アバターの色を設宁E
      user[token].avatarAlpha = data.avatarAlpha;//アバターの透�E度を設宁E
      user[token].bubbleOffsetX = data.bubbleOffsetX || 0;
      user[token].bubbleOffsetY = data.bubbleOffsetY || 0;
      user[token].DIR = "S";

      //soundNumの決宁E
      user[token].soundNum = data.userName.length;
      if (data.avatar == "necosuke" || data.avatar == "necosukeMono") {
        user[token].soundNum++;
      }
      user[token].soundNum += data.avatarColor;
      user[token].soundNum = user[token].soundNum % 9;

      random = volumeRandom("login", "in");

      //アバターお絵描き
      user[token].drawHistory = data.drawHistory;

      // 再接続時は保存座標を復允E
      if (data.reconnectAX !== undefined) {
        user[token].AX = data.reconnectAX;
        user[token].AY = data.reconnectAY;
      }

      if (data.reconnectAX !== undefined) {
        announce = user[token].userName + "ぁE + data.toRoom + "に再�E室しました、E + time();
      } else {
        announce = user[token].userName + "ぁE + data.toRoom + "に入室しました、E + time();
      }
    } else {//loginRoomから以外�E晁E
      //退室処琁E
      rooms[fromRoom].usersToken.delete(token);//允E�E部屋�Eユーザーリストから削除

      if (data.train) {
        announce = user[token].userName + "が電車に乗り込みました、ゆんやー�E�E + time();
      } else {
        announce = user[token].userName + "ぁE + data.toRoom + "に移動しました、E + time();
      }

      if (fromRoom === "昁E") {
        setStarRandomColor();
      }

      socket.broadcast.to(fromRoom).emit("otherLeft", {//自刁E��外が部屋を出た場吁E
        token: token,
        random: volumeRandom(fromRoom, "out"),
        announce: announce,
        starColors: starColors,
      });
    }

    //入室スポット座標（ログイン・部屋移動どちらでも適用�E�E
    switch (data.toSpot) {
      case "entranceCloud1":
        user[token].AX = 500;
        user[token].AY = 80;
        user[token].DIR = "S";
        user[token].is2F = false;
        break;
      case "grassFromEntrance": // エントランスから草原へ�E�左下に出現�E�⭁E座標要調整
        user[token].AX = 100;
        user[token].AY = 430;
        user[token].DIR = "NE";
        break;
      case "entranceMainSpot": // エントランス�E�ログイン用�E�E
        user[token].AX = 415;
        user[token].AY = 315;
        user[token].DIR = "S";
        user[token].is2F = false;
        break;
      case "entranceTrainSpot": // エントランス�E��E車用�E�E
        user[token].AX = 550;
        user[token].AY = 125;
        user[token].DIR = "S";
        user[token].is2F = false;
        break;
      case "entranceFromMeadow":
        user[token].AX = 650;
        user[token].AY = 315;
        user[token].DIR = "NW";
        user[token].is2F = true;
        break;
      case "outerSpaceMainSpot":
        user[token].AX = 200;
        user[token].AY = 300;
        user[token].DIR = "S";
        break;
      case "star1EntrySpot":
        user[token].AX = 334;
        user[token].AY = 450;
        user[token].DIR = "N";
        break;
    }

    if (fromRoom !== "loginRoom") {
      user[token].msg = "";

      if (data.train) {
        announce = user[token].userName + "が電車に乗ってきました、E + time();
      } else {
        announce = user[token].userName + "ぁE + fromRoom + "から移動してきました、E + time();
      }
      random = volumeRandom(data.toRoom, "in");
    }


    if (fromRoom !== data.toRoom) {
      socket.leave(fromRoom);
      socket.join(data.toRoom);
    }

    // 期限刁E��の看板を除去してから送信
    const now = Date.now();
    rooms[data.toRoom].signs = rooms[data.toRoom].signs.filter(s => !s.endTime || s.endTime > now);

    io.to(socket.id).emit("joineRoom", {
      user: user,
      announce: announce,
      fromRoom: fromRoom,
      toRoom: data.toRoom,
      drawHistory: rooms[data.toRoom].drawHistory,
      random: random,
      starColors: starColors,
      signs: rooms[data.toRoom].signs,
    });

    socket.broadcast.to(data.toRoom).emit("otherJoined", {
      userName: user[token].userName,
      token: token,
      avatarAspect: user[token].avatarAspect,
      avatarColor: user[token].avatarColor,
      avatarAlpha: user[token].avatarAlpha,
      AX: user[token].AX,
      AY: user[token].AY,
      DIR: user[token].DIR,
      sit: user[token].sit,
      sleep: user[token].sleep,
      announce: announce,
      msg: user[token].msg,
      drawHistory: user[token].drawHistory,

      fromRoom: fromRoom,
      toRoom: data.toRoom,
      random: random,

      ridingObject: user[token].ridingObject,
      ridingOffsetX: user[token].ridingOffsetX,
      ridingOffsetY: user[token].ridingOffsetY,

      is2F: user[token].is2F ?? false,

      bubbleOffsetX: user[token].bubbleOffsetX || 0,
      bubbleOffsetY: user[token].bubbleOffsetY || 0,

      allowOthersOekaki: user[token].allowOthersOekaki,
    });

    sleepTime();
  });





  //sleep惁E��を受け取ったら自刁E��外�E部屋�E人にスリープ情報を送る
  socket.on("sleep", () => {
    if (!checkUser()) return;
    if (user[token].sleep) {//寝てた時
      user[token].sleep = false;
      user[token].selfSleep = false;
      user[token].DIR = "S";
    } else {//起きてた時
      user[token].sleep = true;
      user[token].selfSleep = true;
    }
    socket.broadcast.to(user[token].room).emit("sleep", {
      token: token,
      sleep: user[token].sleep,
    });
    user[token].sleepTimeNum = 0;
  });

  //アボンを受け取ったら、アボン設定を行う
  socket.on("abonSetting", data => {
    if (!checkUser()) return;
    let abonMsg;
    if (user[data.token] == null) {
      abonMsg = "そ�E住民�E退出済みでぁE;
      io.to(socket.id).emit("abonSetting", {
        msg: abonMsg,
      });
    } else if (!data.setAbon) {
      abonMsg = user[data.token].userName + "をアボンしました、E;
      io.to(socket.id).emit("abonSetting", {
        msg: abonMsg,
        token: data.token,
      });
    } else {
      abonMsg = user[data.token].userName + "のあぼんをめE��ました";
      io.to(socket.id).emit("abonSetting", {
        msg: abonMsg,
        token: data.token,
        AX: user[data.token].AX,
        AY: user[data.token].AY,
        DIR: user[data.token].DIR,
        sit: user[data.token].sit,
        room: user[data.token].room,
        alpha: user[data.token].avatarAlpha,
        sleep: user[data.token].sleep,
      });
    }
    sleepTime();
  });


  //tapイベンチE
  socket.on('tapMap', data => {
    if (!checkUser()) return;

    // 座標更新
    user[token].AX = data.AX || user[token].AX;
    user[token].AY = data.AY || user[token].AY;
    user[token].DIR = data.DIR;
    user[token].sit = data.sit !== undefined ? data.sit : user[token].sit;

    // ⭁E乗車状態�E更新
    if (data.moveType === "relative") {
      // 相対移動�E場合：乗車情報を保孁E
      user[token].ridingObject = data.targetObject;
      user[token].ridingOffsetX = data.relativeX;
      user[token].ridingOffsetY = data.relativeY;
    } else {
      // 絶対移動�E場合：乗車情報をクリア
      user[token].ridingObject = null;
      user[token].ridingOffsetX = 0;
      user[token].ridingOffsetY = 0;
    }

    // 他�Eクライアントに送信
    socket.broadcast.to(user[token].room).emit("tapMap", {
      token: token,
      DIR: user[token].DIR,
      AX: user[token].AX,
      AY: user[token].AY,
      sit: user[token].sit,
      moveType: data.moveType || "absolute",
      targetObject: data.targetObject,
      relativeX: data.relativeX,
      relativeY: data.relativeY
    });
  });


  // 自刁E�E物琁E��態（位置・乗車）をサーバ�Eに通知 ↁE他クライアントへ配信
  socket.on('transformData', data => {
    if (!checkUser()) return;

    // 墁E��制陁E
    const AX = data.fromCloud ? data.AX : Math.max(0, Math.min(660, data.AX));
    const AY = data.fromCloud ? data.AY : Math.max(0, Math.min(460, data.AY));

    user[token].AX = AX;
    user[token].AY = AY;
    user[token].DIR = data.DIR;
    user[token].is2F = data.is2F ?? user[token].is2F ?? false;

    if (data.ridingData) {
      user[token].ridingObject = data.ridingData.objectName;
      user[token].ridingOffsetX = data.ridingData.offsetX;
      user[token].ridingOffsetY = data.ridingData.offsetY;
    } else {
      user[token].ridingObject = null;
      user[token].ridingOffsetX = 0;
      user[token].ridingOffsetY = 0;
    }

    socket.broadcast.to(user[token].room).emit("transformOtherAvatarData", {
      token,
      AX,
      AY,
      DIR: data.DIR,
      reason: data.reason,
      isFalling: data.isFalling,
      is2F: user[token].is2F ?? false,
      ridingData: user[token].ridingObject ? {
        objectName: user[token].ridingObject,
        offsetX: user[token].ridingOffsetX,
        offsetY: user[token].ridingOffsetY,
      } : null,
    });
  });

  // transformDataFromOther は廁E���E�他クライアントによる他人の位置報告�E使わなぁE��E
  socket.on('transformDataFromOther', () => {});


  socket.on("sitChange", data => {//座る�E立つ
    if (!checkUser()) return;
    user[token].DIR = data.DIR;
    user[token].sit = data.sit;//座る�E立つの状態を設宁E
    socket.broadcast.to(user[token].room).emit("sitChange", {
      token: token,
      DIR: data.DIR,
      sit: data.sit,
      AX: data.AX,
      AY: data.AY,
    });
    sleepTime();
  });

  socket.on("alphaChange", data => {//透�Eにする
    if (!checkUser()) return;
    user[token].avatarAlpha = data.alpha;//アバターの透�E度を設宁E
    if (user[token].room !== "loginRoom") {
      socket.broadcast.to(user[token].room).emit("alphaChange", {
        token: token,
        alpha: data.alpha,
      });
    }
    sleepTime();
  });



  //クライアントからメチE��ージを受けとったら送信
  socket.on("emit_msg", data => {
    if (!checkUser()) return;

    let fontColor = "black";
    if (data.msg == "スシ" || data.msg == "�E��E�" || data.msg == "すし" || data.msg == "🍣" || data.msg == "寿司" || data.msg == "鮨" || data.msg == "susi") {
      data.msg += "(" + new Date().getHours().toLocaleString() + ":" + new Date().getMinutes().toLocaleString() + ")";
      fontColor = "white";
    }
    if (data.msg == "もみころ") {
      data.msg += "(もみじゆるさん�E略)";
    }
    if (data.carryOver) {
      user[token].msg = data.msg;
      user[token].carryOver = true;

      //最後に発言したcarryOverメチE��ージをuserの最後に入れなおす
      let value = user[token];
      delete user[token];
      user[token] = value;

    } else {//carryOverじゃなぁE��ら、userのメチE��ージ惁E��は消しとぁE
      user[token].msg = "";
      user[token].carryOver = false;
    }


    if (data.msg == "#list" || data.msg == "#�E�ｽ�E�E || data.msg == "#リスチE) {
      let listName = [];
      let listToken = [];
      let n = 0;
      Object.keys(user).forEach(key => {
        if (user[key].room == user[token].room) {
          listName[n] = user[key].userName;
          listToken[n] = key;
          n++;
        }
      });
      io.to(socket.id).emit("list", {
        listName: listName,
        listToken: listToken,
      });


    } else if (data.msg == "#train" || data.msg == "#�E�E��ｲ�E�E || data.msg == "#トレイン" || data.msg == "#rula" || data.msg == "#�E�ｰ�E�E || data.msg == "#ルーラ" || data.msg == "#電軁E) {

      let trainList = [];
      for (let i = 0; i < roomNameList.length; i++) {
        trainList[i] = roomNameList[i] + ":";
        Object.keys(user).forEach(key => {
          if (user[key].room === roomNameList[i]) {
            if (user[key].video && user[key].audio) {
              trainList[i] += user[key].userName + "📺🔊 "
            } else if (user[key].video) {
              trainList[i] += user[key].userName + "📺 "
            } else if (user[key].audio) {
              trainList[i] += user[key].userName + "🔊 "
            } else {
            }
          }
        });
        trainList[i] += rooms[roomNameList[i]].usersToken.size;
      }

      io.to(socket.id).emit("train", {
        roomNameList: roomNameList,
        trainList: trainList,
      });
    } else {
      io.to(user[token].room).emit("emit_msg", {
        userName: user[token].userName,
        msg: data.msg,
        token: token,
        carryOver: data.carryOver,
        fontColor: fontColor,
        soundNum: user[token].soundNum,
      });
    }
    sleepTime();
  });


  //お絵描き関連
  socket.on("oekaki", data => {
    if (!checkUser()) return;
    if (user[token].room !== "loginRoom") {
      if (data.avatarOekakiToken && user[data.avatarOekakiToken]?.allowOthersOekaki === false) return;
      const target = data.avatarOekakiToken ? user[data.avatarOekakiToken] : rooms[user[token].room];

      target.drawHistory.push(data.line);

      socket.broadcast.to(user[token].room).emit("oekaki", {
        token: token,
        targetToken: data.avatarOekakiToken,
        line: data.line,
      });
      sleepTime();
    }
  });

  socket.on("oekakiClear", data => {
    if (!checkUser()) return;
    if (user[token].room !== "loginRoom") {
      if (data.avatarOekakiToken && user[data.avatarOekakiToken]?.allowOthersOekaki === false) return;
      const target = data.avatarOekakiToken ? user[data.avatarOekakiToken] : rooms[user[token].room];
      target.drawHistory = data.history;
      socket.broadcast.to(user[token].room).emit("oekakiClear", {
        token: token,
        targetToken: data.avatarOekakiToken,
        history: target.drawHistory,
      });
      sleepTime();
    }
  });

  socket.on("setAllowOthersOekaki", data => {
    if (!checkUser()) return;
    user[token].allowOthersOekaki = !!data.allow;
    socket.broadcast.to(user[token].room).emit("setAllowOthersOekaki", {
      token: token,
      allow: user[token].allowOthersOekaki,
    });
  });

  socket.on("undo", data => {//お絵描きを戻ぁE
    if (!checkUser()) return;
    if (user[token].room !== "loginRoom") {
      const target = data.avatarOekakiToken ? user[data.avatarOekakiToken] : rooms[user[token].room];
      target.drawHistory = data.history;
      socket.broadcast.to(user[token].room).emit("undo", {
        token: token,
        targetToken: data.avatarOekakiToken,
        history: target.drawHistory
      });
      sleepTime();
    }
  });




  // ---- 配信関連 ----
  // When a user send a SDP message
  // broadcast to all users in the room
  socket.on("mediaButton", data => {
    if (!checkUser()) return;
    data.from = token;

    if (user[token].room) {
      socket.broadcast.to(user[token].room).emit("mediaButton", data);
    }
  });


  socket.on("webRtcSignal", data => {
    if (!checkUser()) return;
    data.from = token;

    // get send target
    if (data.sendto) {//sendtoの送り允E
      const sendID = socketID[data.sendto];
      socket.to(sendID).emit("webRtcSignal", data);
    }
  });


  socket.on("stream", data => {
    if (!checkUser()) return;
    console.log(data); // ここでundefinedならサーバ�E送信ミス
    if (user[token].room !== "loginRoom") {
      let format = "";
      if (data.format === "videoStart") {
        user[token].video = true;
        format = "が動画配信を始めました";
      } else if (data.format === "videoStop") {
        user[token].video = false;
        format = "が動画配信を終わりました";
      } else if (data.format === "audioStart") {
        user[token].audio = true;
        format = "が音声配信を始めました";
      } else if (data.format === "audioStop") {
        format = "が音声配信を終わりました";
        user[token].audio = false;
      }
      io.to(user[token].room).emit("stream", {
        msg: user[token].userName + format + time(),
        token: token,
      });
      sleepTime();
    }
  });


  // 退出晁E
  socket.on("createSign", data => {
    if (!checkUser()) return;
    const roomName = user[token].room;
    const signId = token + "_" + Date.now();
    const signData = {
      id: signId,
      x: data.x,
      y: data.y,
      cloudRelX: data.cloudRelX ?? null, // 雲の上�E場合�E雲相対X
      boardText: data.boardText,
      clickText: data.clickText,
      durationMs: data.durationMs,
      endTime: data.durationMs > 0 ? Date.now() + data.durationMs : 0,
    };
    rooms[roomName].signs.push(signData);
    // 自刁E��含む部屋�E員に送信
    io.to(roomName).emit("createSign", signData);
    // タイマ�Eで自動削除
    if (data.durationMs > 0) {
      setTimeout(() => {
        rooms[roomName].signs = rooms[roomName].signs.filter(s => s.id !== signId);
        io.to(roomName).emit("removeSign", { id: signId });
      }, data.durationMs);
    }
  });

  socket.on("removeSign", data => {
    if (!checkUser()) return;
    const roomName = user[token].room;
    rooms[roomName].signs = rooms[roomName].signs.filter(s => s.id !== data.id);
    io.to(roomName).emit("removeSign", { id: data.id });
  });

  socket.on("bubbleOffset", data => {
    if (!checkUser()) return;
    user[token].bubbleOffsetX = data.offsetX;
    user[token].bubbleOffsetY = data.offsetY;
    socket.broadcast.to(user[token].room).emit("bubbleOffset", {
      token: token,
      offsetX: data.offsetX,
      offsetY: data.offsetY,
    });
  });

  socket.on("disconnect", () => {
    if (!checkUser()) return;
    if (user[token].room !== "loginRoom") {
      rooms[user[token].room].usersToken.delete(token);//部屋�Eユーザーリストから削除
      io.to(user[token].room).emit("logout", {
        token: token,
        msg: user[token].userName + "が退出しました、E + time(),
        room: user[token].room,
        random: volumeRandom(user[token].room, "logout"),
      });
    }

    //メモリ解放
    delete user[token];
    delete socketID[token];

    // close user connection
    console.log((new Date()) + ' Peer disconnected. id=' + socket.id);
  });
});


